# SelfMailer Backend - Beispiel-Umgebung. Kopiere zu .env (NICHT committen).

# PFLICHT in Produktion: Master-Secret fuer JWT + At-Rest-Verschluesselung.
# Mind. 32 Zeichen, zufaellig. Aendern macht gespeicherte Konto-Passwoerter
# unbrauchbar (muessen neu eingegeben werden).
SELFMAILER_SECRET=bitte-ein-langes-zufaelliges-secret-hier-einsetzen

# SQLite-Pfad. Lokal ./data/selfmailer.db, im Container /data/selfmailer.db
SELFMAILER_DB_PATH=./data/selfmailer.db

# Optional: erzwingt Admin-Token beim First-Run-Setup
SELFMAILER_ADMIN_TOKEN=

# Optional: oeffentliche Basis-URL
SELFMAILER_BASE_URL=

# CORS (Dev): Vite-Devserver
SELFMAILER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
